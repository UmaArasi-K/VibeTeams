# VibeTeams — Environment Variables
# Copy this to .env.local and fill in your values.
# NEVER commit .env.local to git (it's in .gitignore).

# ── Firebase (Frontend) ──
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_PROJECT_ID=promptwars-495103
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id

# ── Google OAuth (Integration Service) ──
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://integration-service-xxx.run.app/api/v1/auth/google/callback

# ── Service Ports (Local Dev) ──
TASK_SERVICE_PORT=8080
INTEGRATION_SERVICE_PORT=8081
NOTIFICATION_SERVICE_PORT=8082
